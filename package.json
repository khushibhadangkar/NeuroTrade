{
  "name": "neurotrade-os",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered stock market prediction platform — LSTM neural network forecasting with an immersive fintech frontend.",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "next dev --port 3010",
    "dev:backend": "cd stock-prediction-frontend/api && NEUROTRADE_PORT=5001 python app.py",
    "build": "next build",
    "start": "next start --port 3010",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "setup": "npm install && pip install -r stock-prediction-frontend/api/requirements.txt",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "keywords": [
    "stock-prediction",
    "lstm",
    "ai",
    "fintech",
    "nextjs",
    "flask"
  ],
  "author": "NeuroTrade",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tanstack/react-query": "^5.64.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "gsap": "^3.12.7",
    "lightweight-charts": "^4.2.2",
    "lucide-react": "^0.468.0",
    "next": "^14.2.29",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.6.0",
    "three": "^0.171.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.171.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.29",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3"
  }
}
