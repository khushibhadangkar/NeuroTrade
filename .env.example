# ─── NeuroTrade OS — Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Backend (Flask) ────────────────────────────────────────────────────────
NEUROTRADE_HOST=127.0.0.1
NEUROTRADE_PORT=5001
NEUROTRADE_DEBUG=false
NEUROTRADE_LOG_LEVEL=INFO
NEUROTRADE_LOG_JSON=true
NEUROTRADE_CORS_ORIGINS=http://localhost:3010,http://localhost:3000

# ─── News API ──────────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org/register
NEWSAPI_KEY=

# ─── AI/LLM (optional, for enhanced narratives) ────────────────────────────
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ─── Model Configuration ───────────────────────────────────────────────────
NEUROTRADE_HISTORY_DAYS=365
NEUROTRADE_SEQUENCE_LENGTH=60
NEUROTRADE_TRAIN_SPLIT=0.80
NEUROTRADE_EPOCHS=100
NEUROTRADE_BATCH_SIZE=32
NEUROTRADE_DROPOUT=0.2
NEUROTRADE_ES_PATIENCE=10
NEUROTRADE_MAX_SYMBOLS=10

# ─── Frontend (Next.js) ─────────────────────────────────────────────────────
NEUROTRADE_API_URL=http://localhost:5001
NEXT_PUBLIC_APP_NAME=NeuroTrade OS
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─── Production Deployment ──────────────────────────────────────────────────
# Frontend: Deploy neurotrade-os/ to Vercel
# Backend: Deploy via Dockerfile to Railway/Render
#
# NEUROTRADE_API_URL=https://your-backend.railway.app
# NEUROTRADE_CORS_ORIGINS=https://your-frontend.vercel.app
