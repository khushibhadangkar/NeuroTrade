{
  "framework": "nextjs",
  "buildCommand": "npm run build --prefix neurotrade-os",
  "installCommand": "npm install --prefix neurotrade-os",
  "outputDirectory": "neurotrade-os/.next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
